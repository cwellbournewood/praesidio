# --- Praesidio Gateway ---
PRAESIDIO_ENV=development
PRAESIDIO_LOG_LEVEL=INFO
PRAESIDIO_HOST=0.0.0.0
PRAESIDIO_PORT=8080

# Comma-separated API keys accepted by the gateway (rotate in prod)
PRAESIDIO_API_KEYS=praesidio-demo-key

# Fail-mode when upstream providers or DLP fail: "open" or "closed"
PRAESIDIO_FAIL_MODE=closed

# Policy bundle location (file path or URL, hot-reloaded)
PRAESIDIO_POLICY_BUNDLE=/etc/praesidio/policies

# --- Storage ---
DATABASE_URL=postgresql+asyncpg://praesidio:praesidio@postgres:5432/praesidio
REDIS_URL=redis://redis:6379/0

# --- Token vault encryption key (32 bytes base64, generate with: openssl rand -base64 32) ---
PRAESIDIO_VAULT_KEY=REPLACE_WITH_BASE64_32_BYTES
# FF3-1 format-preserving encryption key (16/24/32 bytes hex)
PRAESIDIO_FPE_KEY=REPLACE_WITH_HEX_KEY
PRAESIDIO_FPE_TWEAK=REPLACE_WITH_HEX_TWEAK

# --- Upstream LLM providers (configured per-route in policies) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
OLLAMA_BASE_URL=http://ollama:11434

# --- OIDC (optional, for admin UI/admin API) ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Admin UI ---
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_BRAND=Praesidio

# --- Admin / OIDC (admin API + UI auth) ---
PRAESIDIO_ADMIN_REQUIRE_OIDC=0
PRAESIDIO_OIDC_TENANT_CLAIM=tenant_id
# JSON map: OIDC group name -> Praesidio roles
PRAESIDIO_RBAC_GROUP_MAP={"praesidio-admins":["admin"],"praesidio-ops":["operator","viewer"],"praesidio-auditors":["auditor","viewer"],"praesidio-viewers":["viewer"]}

# --- Rate-limiting (per-tenant, Redis-backed) ---
PRAESIDIO_RATE_LIMIT_RPM=600

# --- SIEM webhook egress ---
PRAESIDIO_SIEM_WEBHOOK_URL=
PRAESIDIO_SIEM_WEBHOOK_SECRET=
PRAESIDIO_SIEM_ALLOWED_HOSTS=
PRAESIDIO_SIEM_ALLOW_PRIVATE=0

# --- Signed policy bundles (OCI) ---
# When PRAESIDIO_POLICY_BUNDLE starts with oci://, these are required:
PRAESIDIO_POLICY_SIGNER_IDENTITY=
PRAESIDIO_POLICY_SIGNER_ISSUER=https://token.actions.githubusercontent.com
PRAESIDIO_POLICY_REFRESH_SECONDS=60

# --- Shadow-mode safety: refuse a fully-shadow policy bundle ---
PRAESIDIO_FORBID_FULL_SHADOW=1

# --- OpenTelemetry (used by docker-compose.observability.yml overlay) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=praesidio-gateway

# --- Compliance reporter ---
# Optional dedicated read-only DSN for scripts/compliance_report.py
PRAESIDIO_REPORT_DSN=
