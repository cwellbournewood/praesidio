{
  "annotations": { "list": [] },
  "description": "Section compliance view — per-tenant audit volume, false-positive rate, retention status.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Per-tenant volume",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "id": 1,
      "title": "Audit events / sec by tenant",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (tenant) (rate(decision_total{namespace=~\"$namespace\",tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "table",
      "id": 2,
      "title": "Top 10 tenants by event volume (window)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "topk(10, sum by (tenant) (increase(decision_total{namespace=~\"$namespace\"}[$__range])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": []
      }
    },
    {
      "type": "row",
      "id": 101,
      "title": "Detector quality",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "False-positive rate by detector (operator-reported)",
      "description": "FP rate is derived from /admin/feedback events where the policy team marks a finding as a false positive.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 11 },
      "targets": [
        {
          "expr": "sum by (detector) (rate(detector_feedback_total{namespace=~\"$namespace\",label=\"false_positive\"}[1h])) / clamp_min(sum by (detector) (rate(detector_findings_total{namespace=~\"$namespace\"}[1h])), 1e-9)",
          "legendFormat": "{{detector}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "row",
      "id": 102,
      "title": "Retention",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Oldest audit row (days)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "(time() - section_audit_oldest_event_timestamp_seconds{namespace=~\"$namespace\"}) / 86400",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 365 },
              { "color": "red", "value": 730 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Audit rows total",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 21 },
      "targets": [
        {
          "expr": "sum(section_audit_events_total{namespace=~\"$namespace\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Retention policy",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 21 },
      "targets": [
        {
          "expr": "max(section_audit_retention_days{namespace=~\"$namespace\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "d" } },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "id": 7,
      "title": "Hash-chain verification status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 21 },
      "targets": [
        {
          "expr": "min(section_audit_chain_valid{namespace=~\"$namespace\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "BROKEN", "color": "red" }, "1": { "text": "VALID", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["section", "compliance", "audit"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(decision_total, namespace)",
        "hide": 0,
        "includeAll": true,
        "label": "Namespace",
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(decision_total, namespace)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(decision_total{namespace=~\"$namespace\"}, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": true,
        "name": "tenant",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(decision_total{namespace=~\"$namespace\"}, tenant)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Section — Compliance",
  "uid": "section-compliance",
  "version": 1,
  "weekStart": ""
}
