{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Section gateway overview — throughput, policy decisions, DLP detector performance, vault hit ratio, upstream latency, error rate.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "id": 1,
      "title": "Throughput (req/s by route)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (route) (rate(request_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Error rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(request_total{namespace=~\"$namespace\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(request_total{namespace=~\"$namespace\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Vault hit ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(vault_ops_total{namespace=~\"$namespace\",result=\"hit\"}[5m])) / clamp_min(sum(rate(vault_ops_total{namespace=~\"$namespace\",op=\"lookup\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "row",
      "id": 101,
      "title": "Policy decisions",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "barchart",
      "id": 4,
      "title": "Decisions (stacked, by outcome)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(decision_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "allow" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "transform" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "block" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "error" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }] }
        ]
      },
      "options": {
        "orientation": "vertical",
        "stacking": "normal",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "piechart",
      "id": 5,
      "title": "Decision share (window)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "sum by (decision) (increase(decision_total{namespace=~\"$namespace\"}[$__range]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "row",
      "id": 102,
      "title": "DLP detector latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "p50 detector latency (s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, detector) (rate(detector_latency_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p50 {{detector}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "p99 detector latency (s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, detector) (rate(detector_latency_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p99 {{detector}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "row",
      "id": 103,
      "title": "Upstream",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Upstream latency p95 by provider (s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 29 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(upstream_latency_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p95 {{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Vault ops/s by op",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 29 },
      "targets": [
        {
          "expr": "sum by (op) (rate(vault_ops_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["section", "ai", "security", "dlp"],
  "templating": {
