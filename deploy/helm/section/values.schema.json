{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Section Helm values",
  "type": "object",
  "additionalProperties": true,
  "required": ["image", "replicas", "gateway", "policyBundle", "secrets"],
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonLabels": { "type": "object" },
    "commonAnnotations": { "type": "object" },
    "image": {
      "type": "object",
      "required": ["gateway", "ui"],
      "properties": {
        "gateway": { "$ref": "#/definitions/imageRef" },
        "ui": { "$ref": "#/definitions/imageRef" },
        "pullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": { "name": { "type": "string" } }
          }
        }
      }
    },
    "replicas": {
      "type": "object",
      "properties": {
        "gateway": { "type": "integer", "minimum": 1 },
        "ui": { "type": "integer", "minimum": 1 }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "gateway": { "$ref": "#/definitions/resources" },
        "ui": { "$ref": "#/definitions/resources" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "gateway": { "$ref": "#/definitions/hpa" },
        "ui": { "$ref": "#/definitions/hpa" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "gateway": { "$ref": "#/definitions/pdb" },
        "ui": { "$ref": "#/definitions/pdb" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "service": {
      "type": "object",
      "properties": {
        "gateway": { "$ref": "#/definitions/svc" },
        "ui": { "$ref": "#/definitions/svc" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "object",
          "properties": {
            "gateway": { "type": "string" },
            "ui": { "type": "string" }
          }
        },
        "tls": { "type": "array" }
      }
    },
    "gateway": {
      "type": "object",
      "required": ["failMode"],
      "properties": {
        "env": { "type": "string" },
        "logLevel": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
        },
        "failMode": { "type": "string", "enum": ["open", "closed"] },
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "extraEnv": { "type": "array" },
        "extraVolumes": { "type": "array" },
        "extraVolumeMounts": { "type": "array" },
        "probes": { "type": "object" },
        "upstreamFQDNs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ui": {
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "publicGatewayUrl": { "type": "string" },
        "extraEnv": { "type": "array" }
      }
    },
    "policyBundle": {
      "type": "object",
      "required": ["source", "mountPath", "signatureVerification"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["configmap", "http", "s3", "git"]
        },
        "mountPath": { "type": "string" },
        "signatureVerification": {
          "type": "string",
          "enum": ["cosign", "none"]
        },
        "publicKeyRef": { "type": "string" },
        "http": { "type": "object" },
        "s3": { "type": "object" },
        "git": { "type": "object" }
      }
    },
    "secrets": {
      "type": "object",
      "required": ["externalSecrets"],
      "properties": {
        "externalSecrets": { "type": "boolean" },
        "secretStore": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "kind": {
              "type": "string",
              "enum": ["SecretStore", "ClusterSecretStore"]
            }
          }
        },
        "kmsRef": { "type": "string" },
        "remoteKeys": { "type": "object" },
        "values": { "type": "object" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "allowDnsEgress": { "type": "boolean" },
        "extraEgressCIDRs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string" },
        "port": { "type": "integer" },
        "serviceMonitor": { "type": "object" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "postgres": {
      "type": "object",
      "properties": {
        "embedded": { "type": "boolean" },
        "image": { "type": "string" },
        "storage": { "type": "object" },
        "externalDSN": { "type": "string" }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "embedded": { "type": "boolean" },
        "image": { "type": "string" },
        "storage": { "type": "object" },
        "externalURL": { "type": "string" }
      }
    },
    "migrations": { "type": "object" }
  },
  "definitions": {
    "imageRef": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": { "type": "object" },
        "limits": { "type": "object" }
      }
    },
    "hpa": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "pdb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        }
      }
    },
    "svc": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": { "type": "integer" },
        "annotations": { "type": "object" }
      }
    }
  }
}
