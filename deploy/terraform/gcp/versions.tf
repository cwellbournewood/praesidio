terraform {
  required_version = ">= 1.6"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.40"
    }
    google-beta = {
      source  = "hashicorp/google-beta"
      version = "~> 5.40"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }

  # State backend — uncomment and configure for your environment.
  # backend "gcs" {
  #   bucket = "my-tf-state"
  #   prefix = "section/gcp"
  # }
}
