{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://section.dev/schema/mode.schema.json",
  "title": "Section Mode",
  "description": "Schema for mode.yaml — the manifest of a Section mode bundle.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "section/v1" },
    "kind":       { "const": "Mode" },
    "metadata": {
      "type": "object",
      "required": ["id", "name", "version", "owner", "description"],
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,38}[a-z0-9]$" },
        "name":        { "type": "string", "minLength": 3, "maxLength": 80 },
        "version":     { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$" },
        "owner":       { "type": "string", "format": "email" },
        "maintainers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "email"],
            "properties": {
              "name":  { "type": "string" },
              "email": { "type": "string", "format": "email" },
              "org":   { "type": "string" }
            }
          }
        },
        "description": { "type": "string", "minLength": 20 },
        "homepage":    { "type": "string", "format": "uri" },
        "license":     { "type": "string" }
      }
    },
    "spec": {
      "type": "object",
      "required": ["extends", "risk_tier", "regulations", "includes"],
      "properties": {
        "extends": {
          "oneOf": [
            { "type": "string", "enum": ["none", "pii-strict"] },
            { "type": "string", "pattern": "^[a-z0-9-]+$" }
          ]
        },
        "compatible_overlays": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["strict", "productivity", "public-egress", "research", "airgap"]
          },
          "uniqueItems": true
        },
        "jurisdictions": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{2}(-[A-Z0-9]{1,3})?$" },
          "uniqueItems": true
        },
        "regulations": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "risk_tier": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "includes": {
          "type": "object",
          "required": ["entities", "policy", "compliance", "vault", "ui", "eval"],
          "properties": {
            "entities":   { "type": "string" },
            "policy":     { "type": "string" },
            "compliance": { "type": "string" },
            "vault":      { "type": "string" },
            "ui":         { "type": "string" },
            "eval":       { "type": "string" }
          }
        },
        "signature": {
          "type": "object",
          "properties": {
            "keyref": { "type": "string" },
            "digest": { "type": "string" }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "spec": { "properties": { "risk_tier": { "const": "high" } } } } },
      "then": {
        "$comment": "High-risk modes must declare at least one jurisdiction and one regulation.",
        "properties": {
          "spec": {
            "required": ["jurisdictions", "regulations"]
          }
        }
      }
    }
  ]
}
