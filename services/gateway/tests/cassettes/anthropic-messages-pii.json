{
  "name": "anthropic-messages-pii",
  "description": "Anthropic v1 messages: user request mentions an email; gateway tokenises before upstream; upstream echoes the placeholder; gateway restores on the way back.",
  "provider": "anthropic",
  "route": "/anthropic/v1/messages",
  "upstream": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages"
  },
  "client_request": {
    "headers": {
      "x-api-key": "test-key",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-3-haiku-20240307",
      "max_tokens": 256,
      "messages": [
        {"role": "user", "content": "Please mail bob@example.org with the meeting notes."}
      ]
    }
  },
  "upstream_response": {
    "status": 200,
    "headers": {"content-type": "application/json"},
    "body_template": {
      "id": "msg_cassette_001",
      "type": "message",
      "role": "assistant",
      "model": "claude-3-haiku-20240307",
      "content": [
        {"type": "text", "text": "Confirmed. Sending the notes to {EMAIL_PLACEHOLDER} now."}
      ],
      "stop_reason": "end_turn",
      "usage": {"input_tokens": 21, "output_tokens": 16}
    }
  },
  "policy": "pii_tokenise_email",
  "expectations": {
    "status_code": 200,
    "upstream_must_not_contain": ["bob@example.org"],
    "upstream_must_contain": ["<EMAIL_"],
    "client_must_contain": ["bob@example.org"],
    "client_must_not_contain": ["<EMAIL_"],
    "audit_decision": "transform"
  }
}
