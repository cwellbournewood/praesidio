# Praesidio UI — env contract
#
# Copy to .env.local for local pnpm dev. The docker-compose stack injects the
# same names via the OIDC overlay (see ../../docker-compose.oidc.yml).

# --- Gateway target ---
# Browser-facing gateway URL. Defaults to /api/gateway proxy if unset.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# Server-side (RSC) override — usually the in-cluster service DNS.
PRAESIDIO_GATEWAY_INTERNAL_URL=http://gateway.praesidio.svc.cluster.local:8080

# Next.js rewrite at /api/gateway/* forwards to this URL. Leave unset to
# default to http://localhost:8080 (host) — set explicitly inside Docker
# (e.g. http://gateway:8080).
# PRAESIDIO_GATEWAY_URL=http://localhost:8080

# Force the synthetic data layer (default ON when no gateway is reachable).
NEXT_PUBLIC_MOCK=1

# --- OIDC / NextAuth ---
# Browser-visible issuer URL. From host pnpm dev this is :8081, because the
# Keycloak container exposes 8080 on host 8081.
OIDC_ISSUER=http://localhost:8081/realms/praesidio
OIDC_CLIENT_ID=praesidio
OIDC_CLIENT_SECRET=praesidio-demo-secret

# NextAuth requires its own URL + secret.
# Use the dev-server port (3000 by default, 3010 if running the preview).
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=replace-me-with-32-bytes-of-entropy
